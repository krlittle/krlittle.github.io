---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';

const projects = (await getCollection('projects')).sort(
	(a, b) => a.data.order - b.data.order,
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Projects — ${SITE_TITLE}`} description="Things I've built." />
		<style>
			h1 {
				margin-bottom: 0.25em;
			}
			.subtitle {
				color: rgb(var(--gray));
				margin-bottom: 2em;
			}
			.projects-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
				gap: 1.25em;
			}
			.project-card {
				padding: 1.5em;
				border: 1px solid rgba(var(--gray), 20%);
				border-radius: 8px;
				background: rgba(var(--gray-light), 50%);
				display: flex;
				flex-direction: column;
			}
			.project-card h2 {
				font-size: 1.2em;
				margin-bottom: 0.4em;
			}
			.project-card p {
				font-size: 0.9em;
				color: rgb(var(--gray));
				margin-bottom: 1em;
				flex: 1;
			}
			.tech-tags {
				display: flex;
				flex-wrap: wrap;
				gap: 0.4em;
				margin-bottom: 1em;
			}
			.tag {
				font-size: 0.75em;
				padding: 0.2em 0.6em;
				border-radius: 4px;
				background: rgba(var(--gray), 15%);
				color: rgb(var(--gray));
			}
			.project-links {
				display: flex;
				gap: 1em;
				font-size: 0.85em;
			}
			.empty {
				color: rgb(var(--gray));
				font-style: italic;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Projects</h1>
			<p class="subtitle">Things I've built or am building.</p>

			{
				projects.length === 0 ? (
					<p class="empty">No projects yet. Add one in <code>src/content/projects/</code>.</p>
				) : (
					<div class="projects-grid">
						{projects.map((project) => (
							<div class="project-card">
								<h2>{project.data.title}</h2>
								<p>{project.data.description}</p>
								<div class="tech-tags">
									{project.data.tech.map((t) => (
										<span class="tag">{t}</span>
									))}
								</div>
								<div class="project-links">
									{project.data.github && (
										<a href={project.data.github} target="_blank" rel="noopener noreferrer">
											GitHub
										</a>
									)}
									{project.data.url && (
										<a href={project.data.url} target="_blank" rel="noopener noreferrer">
											Live site
										</a>
									)}
								</div>
							</div>
						))}
					</div>
				)
			}
		</main>
		<Footer />
	</body>
</html>
